// oben links bis mitte-rechts logo; oben recht [einsatz <| coind]

const SCREEN_PORT: u16 = 0;

struct String {
    ptr: &char,
    len: u16,
}

const BOOK_OF_NJ: &String = &String {
    ptr: &"Book of NJ",
    len: 10,
};

struct Surface {
    width: u16,
    height: u16,
    pixels: &u16,
}

fn draw_surface(surface: &Surface, x: i16, y: i16) {
    device!(SCREEN_PORT);
    context!(0, 1);
    let pointer = surface.pixels + surface.width * surface.height;
    let ry = surface.height in for ry downto 0 {
        context!(2, y as u16 + ry);
        let rx = surface.width in for rx downto 0 {
            pointer = pointer - 1;
            let color = *pointer;
            if (color >> 8) alias bool {} else {
                context!(1, x as u16 + rx);
                context!(3, *pointer);
                send!();
            };
        };
    };
}

fn fill_screen(color: u16) {
    device!(SCREEN_PORT);
    context!(0, 1);
    context!(3, color);
    let x = 128 in for x downto 0 {
        context!(1, x);
        let y = 96 in for y downto 0 {
            context!(2, y);
            send!();
        };
    };
}

fn flip_screen() {
    device!(SCREEN_PORT);
    context!(0, 2);
    send!();
}

fn set_title(name: &String) {
    device!(SCREEN_PORT);
    context!(0, 3);
    let i = name.len in for i downto 0 {
        context!(1, i);
        context!(2, name.ptr[i]);
        send!();
    }
}

fn main() {
    set_title(BOOK_OF_NJ);
    loop {
        fill_screen(168);
        // draw_surface(TITLE_SCREEN, +0, +0);
        let idx = 5 in for idx downto 0 {
            Column::render(COLUMNS[idx], idx);
            Column::update(COLUMNS[idx], 500);
        };
        flip_screen();
    }
}

const COLUMNS: &&Column = &[
    &Column { top: BAYERN, center: ELFBAR, bottom: MYA, upcoming: SECOND_TRADE, milipixel_offset: 0 },
    &Column { top: BIER, center: BAYERN, bottom: MYA, upcoming: BAYERN, milipixel_offset: 0 },
    &Column { top: BIER, center: ELFBAR, bottom: BIER, upcoming: BAYERN, milipixel_offset: 0 },
    &Column { top: SECOND_TRADE, center: MYA, bottom: ELFBAR, upcoming: SECOND_TRADE, milipixel_offset: 0 },
    &Column { top: MYA, center: SECOND_TRADE, bottom: BAYERN, upcoming: BIER, milipixel_offset: 0 },
];

struct Column {
    top: &Surface,
    center: &Surface,
    bottom: &Surface,
    upcoming: &Surface,
    milipixel_offset: u16,
}

fn Column::update(self: &Column, offset: u16) {
    self.milipixel_offset = self.milipixel_offset + offset;
    if ((self.milipixel_offset - 24000) >> 15) alias bool {
        self.milipixel_offset = self.milipixel_offset - 24000;
        self.top = self.center;
        self.center = self.bottom;
        self.bottom = self.upcoming;
        self.upcoming = random::symbol();
    }
}

fn Column::render(self: &Column, column_idx: u16) {
    let x = (6 + column_idx * 24) as i16;
    let y = (22 - self.milipixel_offset / 1000) as i16;
    draw_surface(self.top, x, y);
    draw_surface(self.center, x, y + +24);
    draw_surface(self.bottom, x, y + +48);
    draw_surface(self.upcoming, x, y + +72);
}

fn random::symbol() -> &Surface {
    SYMBOLS[random::next() alias u16 / 13108]
}

const random::SEED: &u16 = &0;

fn random::next() -> undefined[1] {
    let seed = *random::SEED;
    let is_even = ((seed & 1) ^ 1) alias bool;
    seed = seed >> 1;
    if (is_even) {
        seed = seed ^ 46080;
    };
    *random::SEED = seed;
    seed alias undefined
}

fn random::salt(salt: u16) {
    *random::SEED = *random::SEED ^ salt;
}

const SYMBOLS: &&Surface = &[
    BAYERN,
    ELFBAR,
    MYA,
    SECOND_TRADE,
    BIER,
];

