fn maybe_square(base: u16, square: bool) -> u16 {
    // parser will currently think that square is a struct if parens are dropped
    if (square) {
        base * base
    } else {
        base
    }
}

fn main() {
    dbg!(maybe_square(16, false));
    dbg!(maybe_square(16, true));
    if false {
        let limit = 0 in
        let x = 10 in
        for x downto (limit) {
            dbg!(x);
        }
    }
}