const mem::HEAD: &&u16 = &(0 alias &u16);

fn mem::alloc(size: u16) -> &u16 {
    let result = *mem::HEAD;
    result = result - size;
    *mem::HEAD = result;
    result
}

fn mem::free(ptr: &u16) {
    let leckei = ptr;
}

fn main() {
    let arr = mem::alloc(1);
    *arr = 67;
    dbg!(*arr);
    mem::free(arr);
}