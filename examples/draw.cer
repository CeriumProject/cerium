fn color_at(x: u16, y: u16) -> u16 {
    x * x + y * y
}

fn draw(getter: &fn(u16, u16) -> u16) {
    device!(0);
    context!(0, 1);
    let x = 128 in for x downto 0 {
        context!(1, x);
        let y = 96 in for y downto 0 {
            context!(2, y);
            context!(3, getter(x, y));
            send!();
        };
    };
}

fn flip() {
    device!(0);
    context!(0, 2);
    send!();
}

fn main() {
    let f = color_at;
    loop {
        draw(f);
        flip();
    }
}