const TERMINAL_DEVICE: u16 = 1;

struct String {
    ptr: &char,
    len: u16,
}

const DEI_MUDA: &String = &String {
    ptr: &"Deine Mom!\n",
    len: 11,
};

fn print(string: &String) {
    device!(TERMINAL_DEVICE);
    context!(0, 1);
    let ptr = string.ptr;
    let i = string.len in for i downto 0 {
        context!(1, *ptr);
        ptr = ptr + 1;
        send!();
    }
}

fn main() {
    loop {
        print(DEI_MUDA);
    }
}