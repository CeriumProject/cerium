struct Vec2i {
    x: u16,
    y: u16,
}

fn gt(lhs: u16, rhs: u16) -> bool {
    ((rhs - lhs) >> 15) alias bool
}

fn swap(pt0: &any, pt1: &any) {
    let temp = *pt0;
    *pt0 = *pt1;
    *pt1 = temp;
}

fn triangle(t0: &Vec2i, t1: &Vec2i, t2: &Vec2i, color: u16) {
    if gt(t0.y, t1.y) { swap(&t0, &t1); };
    if gt(t0.y, t2.y) { swap(&t0, &t2); };
    if gt(t1.y, t2.y) { swap(&t1, &t2); };
    let total_height = t2.y - t0.y;

    device!(DISPLAY_PORT);
    context!(0, 1);
    context!(3, color);
    let y = t1.y + 1 in for y downto t0.y {
        let segment_height = t1.y - t0.y + 1;
        let alpha = (y - t0.y) as f16 / total_height as f16;
        let beta = (y - t0.y) as f16 / segment_height as f16;
        let a = t0.x + ((t2.x - t0.x) as i16 as f16 * alpha) as i16 as u16;
        let b = t0.x + ((t1.x - t0.x) as i16 as f16 * beta) as i16 as u16;
        if gt(a, b) { swap(&a, &b); };
        context!(2, y);
        let j = b + 1 in for j downto (a) {
            context!(1, j);
            send!();
        };
    };

    device!(DISPLAY_PORT);
    context!(0, 1);
    context!(3, color);
    let y = t2.y + 1 in for y downto t1.y {
        let segment_height = t2.y - t1.y + 1;
        let alpha = (y - t0.y) as f16 / total_height as f16;
        let beta = (y - t1.y) as f16 / segment_height as f16;
        let a = t0.x + ((t2.x - t0.x) as i16 as f16 * alpha) as i16 as u16;
        let b = t1.x + ((t2.x - t1.x) as i16 as f16 * beta) as i16 as u16;
        if gt(a, b) { swap(&a, &b); };
        context!(2, y);
        let j = b + 1 in for j downto (a) {
            context!(1, j);
            send!();
        };
    };
}

const V: &Vec2i = &Vec2i {
    x: 20,
    y: 6,
};

const W: &Vec2i = &Vec2i {
    x: 66,
    y: 9,
};

const X: &Vec2i = &Vec2i {
    x: 16,
    y: 77,
};

const Y: &Vec2i = &Vec2i {
    x: 61,
    y: 50,
};

const Z: &Vec2i = &Vec2i {
    x: 101,
    y: 52,
};

const A: &Vec2i = &Vec2i {
    x: 80,
    y: 80,
};

const DISPLAY_PORT: u16 = 0;
const GREEN: u16 = 48;
const RED: u16 = 192;
const ORANGE: u16 = 208;
const BLUE: u16 = 12;
const MAGENTA: u16 = 196;
const PURPLE: u16 = 204;

fn main() {
    loop {
        triangle(V, W, Y, RED);
        triangle(V, X, Y, ORANGE);
        triangle(W, Y, Z, BLUE);
        triangle(X, Y, A, MAGENTA);
        triangle(A, Y, Z, PURPLE);
        device!(DISPLAY_PORT);
        context!(0, 2);
        send!();
        Y.x = ((Y.x + 30) & 127 | 64) - 29;
    }
}