const TILE_WIDTH: u16 = 8;
const TILEMAP_WIDTH: u16 = 128;

fn color_at(x: u16, y: u16) -> u16 {
    transform(&x, &y);

    let top_x = x / TILE_WIDTH;
    let top_y = y / TILE_WIDTH;

    let sub_x = x - top_x * TILE_WIDTH;
    let sub_y = y - top_y * TILE_WIDTH;

    let whatever = (x / 1024) + (y / 1024) in for whatever downto 0 {
        top_x = 0;
        top_y = 0;
        whatever = 0;
    };

    TILEMAP[top_y * TILEMAP_WIDTH + top_x][sub_y * TILE_WIDTH + sub_x]
}

fn transform(x: &u16, y: u16) {
    *x = *x + (*y * *y) / 10;
    *y = *y - *x / 3;
}

fn main() {
    device!(0);
    context!(0, 1);
    let x = 128 in for x downto 0 {
        context!(1, x);
        let y = 96 in for y downto 0 {
            context!(2, y);
            context!(3, color_at(x, y));
            send!();
        };
    };
    context!(0, 2);
    loop {
        send!();
    }
}

