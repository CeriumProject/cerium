fn memcpy(dst: &fn(f16) -> f16, src: &fn(f16) -> f16, len: u16) {
    for len downto 0 {
        *dst = *src;
        dst = dst + 1;
        src = src + 1;
    }
}

fn sqr(input: f16) -> f16 {
    input * input
}

fn main() {
    let func = 10000 alias &fn(f16) -> f16;
    memcpy(func, sqr, 100);
    dbg!(func(98.53));
}